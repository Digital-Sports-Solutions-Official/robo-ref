# ---- Supabase (public; safe to expose to the browser) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- VEX events API (SERVER ONLY — never prefix with NEXT_PUBLIC) ----
# Request a token at https://events.vex.com/api/v2  (Login -> Request Access)
VEX_API_TOKEN=

# ---- Report Issue -> GitHub (SERVER ONLY) ----
# A fine-grained PAT with Issues: read/write on the target repo
GITHUB_TOKEN=
GITHUB_ISSUES_REPO=owner/repo
